# ============================================
# Enterprise MCP Server — Environment Variables
# ============================================

# --- Server ---
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=9000
ENVIRONMENT=development
DEBUG=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://mcp_user:password@localhost:5432/mcp_server
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=1800

# --- OPN-Agent Paths ---
OPN_AGENT_BASE_DIR=d:/agent share/src/OPN-Agent
OPN_DATA_INPUT_DIR=d:/agent share/src/OPN-Agent/AI_open_negotiation/Data/Input
OPN_DATA_OUTPUT_DIR=d:/agent share/src/OPN-Agent/AI_open_negotiation/Data/Output

# --- Filesystem MCP Server ---
FILESYSTEM_ALLOWED_DIRS=["d:/agent share/src/OPN-Agent/AI_open_negotiation/Data"]

# --- Session Management ---
SESSION_TTL_SECONDS=3600
SESSION_MAX_REFRESHES=3
SESSION_ABSOLUTE_TIMEOUT_SECONDS=14400
SESSION_MAX_PER_KEY=5

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_MCP=60/minute

# --- Security ---
API_KEY_HEADER=X-API-Key
HMAC_SIGNING_ENABLED=false
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300

# --- Compliance ---
AUDIT_RETENTION_DAYS=2555
AUDIT_LOCAL_LOG_DIR=logs/audit

# --- Gmail API ---
# OAuth credentials file from Google Cloud Console
GMAIL_CREDENTIALS_PATH=d:/agent share/credentials/gmail_credentials.json
# Auto-generated token file (created after first OAuth consent)
GMAIL_TOKEN_PATH=d:/agent share/credentials/gmail_token.json
